# General ignores
#-------------------------------------------------------------------------------
# Operating System files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~

# IDE and editor specific files
.idea/
.vscode/
.claude/
CLAUDE.md
*.suo
*.user
*.userosscache
*.sln.docstates
*.project.json
*.tmproj
*.sublime-project
*.sublime-workspace
.devcontainer
# Eclipse / Java IDE
.classpath
.project
.settings
.metadata/
Servers/

# Vagrant
.vagrant

# Log files (generic, will catch logs from any tool/language)
*.log
logs/
*.log.*

# Environment files - typically sensitive, should not be committed
.env
.env.*
!.env.example
!.env.sample
# Allow shared env templates in subprojects
!test-suite/e2e/.env.devnet
# If you have .env files specific to subprojects, e.g. subproject/.env,
# the .env rule above will catch them.

# Sensitive credential files
google-serviceaccount.json

# Build output & temporary directories (generic)
.cache/
.buildx-cache/
temp/
tmp/
_out/

# Archives
*.zip
*.tar
*.gz
*.rar
*.7z
*.deb

# Local configuration and backup files
.local/
*-local.*
.local
.api/

# API linting
.spectral_*.yaml

# Test / scan reports
report.*

# Node.js specific
#-------------------------------------------------------------------------------
# Dependency directories
node_modules/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Compiled TypeScript files info
*.tsbuildinfo

# Build output directories
build/
dist/
out/
public/ # If serving static assets from a 'public' dir built by a framework
.next/
.nuxt/
.svelte-kit/

# Package manager lock files
package-lock.json
package.json

# Test reports and coverage (often from Node.js tools like Jest, Mocha)
coverage/
.nyc_output/
junit/
mochawesome-report/

# Python specific
#-------------------------------------------------------------------------------
.venv

# Rust specific
#-------------------------------------------------------------------------------
# Build artifacts directory
target/
